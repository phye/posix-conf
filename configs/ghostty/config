# Ghost Configuration
macos-titlebar-style = tabs

font-family = "MonaspiceKr Nerd Font Mono"
font-size = 14

theme = light:Pro Light,dark:Atom One Dark

# alternate
# theme = light:Light Owl,dark:Atom One Dark

# bad
#theme = light:Rose Pine Dawn,dark:Rose Pine
#theme = light:Night Owlish Light,dark:Atom One Dark

# Keybindings

# Bind M-w to send Esc-w sequence
keybind = cmd+f=text:\x1bf
keybind = cmd+b=text:\x1bb
keybind = cmd+n=text:\x1bn
keybind = cmd+p=text:\x1bp
keybind = cmd+q=text:\x1bq
keybind = cmd+w=text:\x1bw
keybind = cmd+x=text:\x1bx
keybind = alt+x=text:\x1bx
keybind = alt+;=text:\x1b;
keybind = alt+f=text:\x1bf
keybind = alt+b=text:\x1bb
keybind = alt+p=text:\x1bp
keybind = alt+n=text:\x1bn
keybind = alt+v=text:\x1bv
keybind = cmd+alt+r=reload_config
keybind = cmd+r=text:reset\n
keybind = global:cmd+ctrl+t=toggle_quick_terminal